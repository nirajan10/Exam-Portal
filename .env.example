# Copy to .env and fill in values
DB_PASSWORD=changeme_strong_password
JWT_SECRET=changeme_at_least_32_chars_long_secret
# Run: stat -c '%g' /var/run/docker.sock  to get your docker group GID
DOCKER_GID=999
# Superadmin bootstrap — on first startup, a superadmin account is auto-created
# if no superadmin exists yet. Leave blank to skip bootstrapping.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme_strong_admin_password
